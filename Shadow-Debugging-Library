       ]
       
       for check in checks:
           code = re.sub(check, '', code, flags=re.DOTALL)
       
       code = re.sub(r'getfenv\s*\(\s*(\d+)\s*\)', r'_G', code)
       code = re.sub(r'setfenv\s*\(\s*(\d+)\s*,\s*([^)]+)\)', r'-- setfenv(\1, \2)', code)
       code = re.sub(r'debug\.getinfo\s*\(\s*[^)]*\)', r'{}', code)
