class VMR:
   def __init__(self):
       self.safe_eval = SafeEvaluator()
       self.ai = ShadowAIEngine()
       self.opcode_mappers = {}
       self.constant_pools = {}
       self.register_states = {}
       self.execution_traces = []
       self.sandbox = ShadowSandbox()
