class ASTTransformer:
   def __init__(self):
       self.variable_counter = 0
       self.variable_map = {}
       self.constants = {}
       self.safe_eval = SafeEvaluator()
   
   def transform(self, code: str) -> str:
       if not LUA_PARSER_AVAILABLE:
           return self._regex_transform(code)
       
       try:
           tree = lua_ast.parse(code)
           tree = self._fold_constants(tree)
           tree = self._rename_variables(tree)
           tree = self._eliminate_dead_code(tree)
           return lua_ast.to_lua_source(tree)
       except:
           return self._regex_transform(code)
   
   def _regex_transform(self, code: str) -> str:
       code = self._fold_constants_regex(code)
       code = self._rename_variables_regex(code)
       code = self._eliminate_dead_code_regex(code)
       return code
   
   def _fold_constants(self, node):
       if isinstance(node, (Number, String, Nil, Boolean)):
           return node
       
       if isinstance(node, BinOp):
           left = self._fold_constants(node.left)
           right = self._fold_constants(node.right)
           
           if isinstance(left, Number) and isinstance(right, Number):
               try:
                   if isinstance(node.op, Add):
                       return Number(left.n + right.n)
                   elif isinstance(node.op, Sub):
                       return Number(left.n - right.n)
                   elif isinstance(node.op, Mult):
                       return Number(left.n * right.n)
                   elif isinstance(node.op, Div):
                       return Number(left.n / right.n)
                   elif isinstance(node.op, Mod):
                       return Number(left.n % right.n)
                   elif isinstance(node.op, Pow):
                       return Number(left.n ** right.n)
               except:
                   pass
           
           node.left = left
           node.right = right
           return node
       
       if isinstance(node, UnOp):
           operand = self._fold_constants(node.operand)
           if isinstance(operand, Number):
               if isinstance(node.op, UMinus):
                   return Number(-operand.n)
               elif isinstance(node.op, Not):
                   return Boolean(not operand.n)
           
           node.operand = operand
           return node
       
       if hasattr(node, 'fields'):
           for field_name in node.fields:
               field_value = getattr(node, field_name)
               if isinstance(field_value, list):
                   setattr(node, field_name, [self._fold_constants(item) for item in field_value])
               elif field_value is not None:
                   setattr(node, field_name, self._fold_constants(field_value))
       
       return node
   
   def _rename_variables(self, node):
       if isinstance(node, Name):
           if node.id not in self.variable_map:
               self.variable_map[node.id] = f'var_{self.variable_counter}'
               self.variable_counter += 1
           node.id = self.variable_map[node.id]
           return node
       
       if hasattr(node, 'fields'):
           for field_name in node.fields:
               field_value = getattr(node, field_name)
               if isinstance(field_value, list):
                   setattr(node, field_name, [self._rename_variables(item) for item in field_value])
               elif field_value is not None:
                   setattr(node, field_name, self._rename_variables(field_value))
       
       return node
   
   def _eliminate_dead_code(self, node):
       if isinstance(node, Block):
           new_body = []
           for stmt in node.body:
               if not self._is_dead_code(stmt):
                   new_body.append(self._eliminate_dead_code(stmt))
           node.body = new_body
           return node
       
       if hasattr(node, 'fields'):
           for field_name in node.fields:
               field_value = getattr(node, field_name)
               if isinstance(field_value, list):
                   setattr(node, field_name, [self._eliminate_dead_code(item) for item in field_value])
               elif field_value is not None:
                   setattr(node, field_name, self._eliminate_dead_code(field_value))
       
       return node
   
   def _is_dead_code(self, node):
       if isinstance(node, LocalAssign):
           if len(node.values) == 1:
               value = node.values[0]
               if isinstance(value, (Number, String, Nil, Boolean, Table)):
                   return True
       
       if isinstance(node, Do):
           if not node.body:
               return True
       
       if isinstance(node, While):
           if isinstance(node.test, Boolean) and not node.test.b:
               return True
       
       return False
   
   def _fold_constants_regex(self, code: str) -> str:
       patterns = [
           (r'(\d+)\s*\+\s*(\d+)', lambda m: str(int(m.group(1)) + int(m.group(2)))),
           (r'(\d+)\s*-\s*(\d+)', lambda m: str(int(m.group(1)) - int(m.group(2)))),
           (r'(\d+)\s*\*\s*(\d+)', lambda m: str(int(m.group(1)) * int(m.group(2)))),
           (r'(\d+)\s*/\s*(\d+)', lambda m: str(int(m.group(1)) // int(m.group(2)))),
           (r'(\d+)\s*%\s*(\d+)', lambda m: str(int(m.group(1)) % int(m.group(2)))),
           (r'(\d+)\s*\^\s*(\d+)', lambda m: str(int(m.group(1)) ** int(m.group(2)))),
           (r'not\s+not\s+(\w+)', r'\1'),
           (r'true\s+and\s+(\w+)', r'\1'),
           (r'false\s+and\s+(\w+)', r'false'),
           (r'true\s+or\s+(\w+)', r'true'),
           (r'false\s+or\s+(\w+)', r'\1'),
       ]
       
       for pattern, replacement in patterns:
           code = re.sub(pattern, replacement, code)
       
       return code
   
   def _rename_variables_regex(self, code: str) -> str:
       local_pattern = r'local\s+(\w+)'
       locals_found = re.findall(local_pattern, code)
       
       for i, var in enumerate(locals_found):
           if not var.startswith('var_'):
               new_name = f'var_{i}'
               code = re.sub(rf'\b{var}\b', new_name, code)
       
       return code
   
   def _eliminate_dead_code_regex(self, code: str) -> str:
       patterns = [
           r'local\s+\w+\s*=\s*\d+\s*[\+\-]\s*\d+[^;]*',
           r'\blocal\s+\w+\s*=\s*\w+\s*;?\s*\n',
           r'local\s+\w+\s*=\s*\{\s*\}',
           r'local\s+\w+\s*=\s*""',
           r'local\s+\w+\s*=\s*0\s*;?',
           r'if\s+true\s+then\s+else\s+end',
           r'if\s+false\s+then\s+else\s+end',
           r'while\s+false\s+do.*?end',
           r'while\s+true\s+do\s*end',
       ]
       
       for pattern in patterns:
           code = re.sub(pattern, '', code, flags=re.DOTALL)
       
       return code

class ControlFlowAnalyzer:
   def __init__(self):
       self.cfg = {}
       self.blocks = []
       self.z3_solver = Solver() if Z3_AVAILABLE else None
   
   def analyze(self, code: str) -> str:
       self._build_cfg(code)
       code = self._unflatten_control_flow(code)
       code = self._solve_opaque_predicates(code)
       return code
   
   def _build_cfg(self, code: str):
       lines = code.split('\n')
       self.blocks = []
       current_block = []
       
       for i, line in enumerate(lines):
           stripped = line.strip()
           if stripped:
               current_block.append((i, stripped))
               
               if any(stripped.startswith(x) for x in ['if', 'while', 'for', 'repeat', 'return', 'goto', 'break']):
                   if current_block:
                       self.blocks.append(current_block)
                       current_block = []
       
       if current_block:
           self.blocks.append(current_block)
       
       for idx, block in enumerate(self.blocks):
           self.cfg[idx] = {
               'lines': block,
               'successors': [],
               'predecessors': [],
           }
           
           if idx < len(self.blocks) - 1:
               self.cfg[idx]['successors'].append(idx + 1)
   
   def _unflatten_control_flow(self, code: str) -> str:
       state_machine_pattern = r'while\s+(\w+)\s*<\s*(\d+)\s*do\s+if\s+\1\s*==\s*(\d+)\s*then'
       matches = list(re.finditer(state_machine_pattern, code))
       
       if len(matches) < 3:
           return code
       
       blocks = []
       var = matches[0].group(1)
       
       for i, match in enumerate(matches):
           state = match.group(3)
           end_pos = matches[i+1].start() if i+1 < len(matches) else len(code)
           block = code[match.start():end_pos]
           
           block_clean = re.sub(rf'if\s+{var}\s*==\s*{state}\s+then\s*', '', block)
           block_clean = re.sub(r'\s*end\s*$', '', block_clean)
           block_clean = re.sub(rf'{var}\s*=\s*{int(state)+1}', '', block_clean)
           block_clean = re.sub(rf'while\s+{var}\s*<\s*\d+\s*do', '', block_clean)
           block_clean = re.sub(r'end\s*$', '', block_clean)
           
           blocks.append(block_clean.strip())
       
       return '\n\n'.join(blocks)
   
   def _solve_opaque_predicates(self, code: str) -> str:
       if not Z3_AVAILABLE:
           return code
       
       opaque_patterns = [
           (r'if\s*\((\d+)\s*%\s*(\d+)\s*==\s*(\d+)\)\s*then', self._solve_mod_predicate),
           (r'if\s*\((\d+)\s*\*\s*(\d+)\s*\+\s*(\d+)\s*==\s*(\d+)\)\s*then', self._solve_linear_predicate),
           (r'if\s*\((\w+)\s*~\s*(\w+)\s*==\s*0\)\s*then', lambda *args: True),
       ]
       
       for pattern, solver_func in opaque_patterns:
           for match in re.finditer(pattern, code):
               result = solver_func(*match.groups())
               if result is True:
                   code = code.replace(match.group(0), 'if true then', 1)
               elif result is False:
                   code = code.replace(match.group(0), 'if false then', 1)
       
       return code
   
   def _solve_mod_predicate(self, a, b, c):
       try:
           a, b, c = int(a), int(b), int(c)
           return (a % b) == c
       except:
           return None
   
   def _solve_linear_predicate(self, a, b, c, d):
       try:
           a, b, c, d = int(a), int(b), int(c), int(d)
           return (a * b + c) == d
       except:
           return None

class VMInstruction:
   def __init__(self, opcode, a, b, c, bx, sbx, original=0, name=""):
       self.opcode = opcode
       self.a = a
       self.b = b
       self.c = c
       self.bx = bx
       self.sbx = sbx
       self.original = original
       self.name = name or self._get_opcode_name(opcode)
       self.resolved_val = None
       self.folded = False
       self.execution_count = 0
       self.next_opcodes = []
   
   def _get_opcode_name(self, opcode):
       opcodes = {
           0: 'MOVE', 1: 'LOADK', 2: 'LOADBOOL', 3: 'LOADNIL', 4: 'GETUPVAL',
           5: 'GETGLOBAL', 6: 'GETTABLE', 7: 'SETGLOBAL', 8: 'SETUPVAL', 9: 'SETTABLE',
           10: 'NEWTABLE', 11: 'SELF', 12: 'ADD', 13: 'SUB', 14: 'MUL', 15: 'DIV',
           16: 'MOD', 17: 'POW', 18: 'UNM', 19: 'NOT', 20: 'LEN', 21: 'CONCAT',
           22: 'JMP', 23: 'EQ', 24: 'LT', 25: 'LE', 26: 'TEST', 27: 'TESTSET',
           28: 'CALL', 29: 'TAILCALL', 30: 'RETURN', 31: 'FORLOOP', 32: 'FORPREP',
           33: 'TFORLOOP', 34: 'SETLIST', 35: 'CLOSE', 36: 'CLOSURE', 37: 'VARARG',
       }
       return opcodes.get(opcode, f'OP_{opcode}')

class ShadowSandbox:
   def __init__(self):
       self.virtual_stack = []
       self.heap = {}
       self.registers = {}
       self.constants = {}
       self.call_stack = []
       self.execution_trace = []
       self.memory_snapshots = []
       self.breakpoints = set()
       self.watchpoints = {}
       self.environment = {
           'print': print,
           'string': string,
           'math': math,
           'table': {},
           'pairs': lambda x: x.items() if isinstance(x, dict) else enumerate(x),
           'ipairs': lambda x: enumerate(x),
           'type': type,
           'tostring': str,
           'tonumber': float,
           'assert': lambda x, y=None: x or (_ for _ in ()).throw(AssertionError(y)),
           'error': lambda x: (_ for _ in ()).throw(Exception(x)),
           'pcall': lambda f, *a: (True, f(*a)) if True else (False, None),
           'xpcall': lambda f, e, *a: (True, f(*a)) if True else (False, e),
           'rawget': lambda t, k: t.get(k),
           'rawset': lambda t, k, v: t.__setitem__(k, v),
           'rawequal': lambda a, b: a is b,
           'unpack': lambda t, i=1, j=None: list(t[i-1:j]) if j else list(t[i-1:]),
           'select': lambda n, *a: a[n-1] if n > 0 else len(a),
           'next': lambda t, k=None: next(iter(t.items())) if k is None else next((kv for kv in t.items() if kv[0] != k), (None, None)),
           'tostring': str,
           'tonumber': lambda x, base=10: int(x, base) if base != 10 else float(x),
           'loadstring': lambda x: compile(x, '<string>', 'exec'),
           'load': lambda x, *a: compile(x.read() if hasattr(x, 'read') else x, '<string>', 'exec'),
           'dofile': lambda f: exec(open(f).read()),
           'require': lambda m: __import__(m),
       }
       self.lua_runtime = LuaRuntime(unpack_returned_tuples=True) if LUPA_AVAILABLE else None
   
   def simulate_call(self, func_bytes: bytes, args: List[Any]) -> Dict[str, Any]:
       self.virtual_stack = list(args)
       self.call_stack.append({'func': func_bytes, 'pc': 0, 'locals': {}, 'upvalues': {}})
       
       try:
           if func_bytes[:4] == b'\x1bLua':
               result = self._simulate_lua_bytecode(func_bytes)
           else:
               result = self._simulate_generic(func_bytes)
           
           return {
               'success': True,
               'result': result,
               'trace': self.execution_trace,
               'heap': self.heap,
               'memory_snapshots': self.memory_snapshots,
               'registers': self.registers,
           }
       except Exception as e:
           return {
               'success': False,
               'error': str(e),
               'trace': self.execution_trace,
               'heap': self.heap,
               'registers': self.registers,
           }
   
   def _simulate_lua_bytecode(self, bytecode: bytes) -> Any:
       pos = 12
       
       def read_int(size: int) -> int:
           nonlocal pos
           val = int.from_bytes(bytecode[pos:pos+size], 'little')
           pos += size
           return val
       
       def read_size_t() -> int:
           return read_int(4)
       
       def read_number() -> float:
           nonlocal pos
           return struct.unpack('<d', bytecode[pos:pos+8])[0]
       
       def read_string() -> str:
           nonlocal pos
           size = read_size_t()
           if size == 0:
               return ""
           result = bytecode[pos:pos+size-1].decode('utf-8', errors='ignore')
           pos += size
           return result
       
       source_len = read_size_t()
       pos += source_len
       
       line_defined = read_int(4)
       last_line_defined = read_int(4)
       num_upvalues = bytecode[pos]
       pos += 1
       num_params = bytecode[pos]
       pos += 1
       is_vararg = bytecode[pos]
       pos += 1
       max_stack_size = bytecode[pos]
       pos += 1
       
       num_instr = read_int(4)
       instructions = []
       
       for _ in range(num_instr):
           instr = read_int(4)
           opcode = instr & 0x3F
           a = (instr >> 6) & 0xFF
           c = (instr >> 14) & 0x1FF
           b = (instr >> 23) & 0x1FF
           bx = (instr >> 14) & 0x3FFFF
           sbx = bx - 131071
           
           instructions.append(VMInstruction(opcode, a, b, c, bx, sbx, instr))
       
       num_const = read_int(4)
       constants = []
       
       for _ in range(num_const):
           const_type = bytecode[pos]
           pos += 1
           
           if const_type == 0:
               constants.append(None)
           elif const_type == 1:
               constants.append(bytecode[pos] != 0)
               pos += 1
           elif const_type == 3:
               constants.append(read_number())
           elif const_type == 4:
               constants.append(read_string())
       
       self.constants = {i: v for i, v in enumerate(constants)}
       
       pc = 0
       while pc < len(instructions):
           if pc in self.breakpoints:
               self.memory_snapshots.append({
                   'pc': pc,
                   'registers': dict(self.registers),
                   'stack': list(self.virtual_stack),
               })
           
           instr = instructions[pc]
           self.execution_trace.append({
               'pc': pc,
               'opcode': instr.name,
               'a': instr.a,
               'b': instr.b,
               'c': instr.c,
               'bx': instr.bx,
               'sbx': instr.sbx,
               'registers': dict(self.registers),
               'stack': list(self.virtual_stack),
           })
           
           if instr.name == 'MOVE':
               self.registers[instr.a] = self.registers.get(instr.b, None)
           
           elif instr.name == 'LOADK':
               self.registers[instr.a] = self.constants.get(instr.bx, None)
           
           elif instr.name == 'LOADBOOL':
               self.registers[instr.a] = instr.b != 0
               if instr.c != 0:
                   pc += 1
           
           elif instr.name == 'LOADNIL':
               for i in range(instr.a, instr.b + 1):
                   self.registers[i] = None
           
           elif instr.name == 'GETUPVAL':
               self.registers[instr.a] = self.call_stack[-1]['upvalues'].get(instr.b, None)
           
           elif instr.name == 'GETGLOBAL':
               name = self.constants.get(instr.bx, None)
               self.registers[instr.a] = self.environment.get(name, None)
           
           elif instr.name == 'GETTABLE':
               table = self.registers.get(instr.b, {})
               key = self.registers.get(instr.c) if instr.c < 256 else self.constants.get(instr.c - 256, None)
               self.registers[instr.a] = table.get(key, None) if isinstance(table, dict) else None
           
           elif instr.name == 'SETGLOBAL':
               name = self.constants.get(instr.bx, None)
               self.environment[name] = self.registers.get(instr.a, None)
           
           elif instr.name == 'SETUPVAL':
               self.call_stack[-1]['upvalues'][instr.b] = self.registers.get(instr.a, None)
           
           elif instr.name == 'SETTABLE':
               table = self.registers.get(instr.a, {})
               key = self.registers.get(instr.b) if instr.b < 256 else self.constants.get(instr.b - 256, None)
               value = self.registers.get(instr.c) if instr.c < 256 else self.constants.get(instr.c - 256, None)
               if isinstance(table, dict):
                   table[key] = value
           
           elif instr.name == 'NEWTABLE':
               self.registers[instr.a] = {}
           
           elif instr.name == 'SELF':
               self.registers[instr.a + 1] = self.registers.get(instr.b, None)
               table = self.registers.get(instr.b, {})
               key = self.constants.get(instr.c, None)
               self.registers[instr.a] = table.get(key, None) if isinstance(table, dict) else None
           
           elif instr.name in ['ADD', 'SUB', 'MUL', 'DIV', 'MOD', 'POW']:
               left = self.registers.get(instr.b, 0)
               right = self.registers.get(instr.c, 0)
               if isinstance(left, (int, float)) and isinstance(right, (int, float)):
                   ops = {'ADD': operator.add, 'SUB': operator.sub, 'MUL': operator.mul, 
                          'DIV': operator.truediv, 'MOD': operator.mod, 'POW': operator.pow}
                   self.registers[instr.a] = ops[instr.name](left, right)
               else:
                   self.registers[instr.a] = None
           
           elif instr.name == 'UNM':
               val = self.registers.get(instr.b, 0)
               self.registers[instr.a] = -val if isinstance(val, (int, float)) else None
           
           elif instr.name == 'NOT':
               val = self.registers.get(instr.b, False)
               self.registers[instr.a] = not val
           
           elif instr.name == 'LEN':
               val = self.registers.get(instr.b, "")
               self.registers[instr.a] = len(val) if isinstance(val, (str, list, dict)) else 0
           
           elif instr.name == 'CONCAT':
               result = ""
               for i in range(instr.b, instr.c + 1):
                   val = self.registers.get(i, "")
                   result += str(val)
               self.registers[instr.a] = result
           
           elif instr.name == 'JMP':
               pc += instr.sbx
               continue
           
           elif instr.name in ['EQ', 'LT', 'LE']:
               left = self.registers.get(instr.b) if instr.b < 256 else self.constants.get(instr.b - 256, None)
               right = self.registers.get(instr.c) if instr.c < 256 else self.constants.get(instr.c - 256, None)
               if instr.b >= 256:
                   left = self.constants.get(instr.b - 256, None)
               if instr.c >= 256:
                   right = self.constants.get(instr.c - 256, None)
               
               ops = {'EQ': operator.eq, 'LT': operator.lt, 'LE': operator.le}
               result = ops[instr.name](left, right)
               if result != (instr.a != 0):
                   pc += 1
           
           elif instr.name == 'TEST':
               val = self.registers.get(instr.a, False)
               if (not val) != (instr.c != 0):
                   pc += 1
           
           elif instr.name == 'TESTSET':
               val = self.registers.get(instr.b, False)
               if (not val) != (instr.c != 0):
                   pc += 1
               else:
                   self.registers[instr.a] = val
           
           elif instr.name == 'CALL':
               func = self.registers.get(instr.a, lambda *x: None)
               num_args = instr.b - 1 if instr.b != 0 else len(self.virtual_stack)
               num_results = instr.c - 1 if instr.c != 0 else 1
               
               args = [self.registers.get(instr.a + i + 1) for i in range(num_args)]
               
               if callable(func):
                   try:
                       result = func(*args)
                       if num_results >= 0:
                           self.registers[instr.a] = result
                   except:
                       self.registers[instr.a] = None
           
           elif instr.name == 'TAILCALL':
               func = self.registers.get(instr.a, lambda *x: None)
               num_args = instr.b - 1 if instr.b != 0 else len(self.virtual_stack)
               args = [self.registers.get(instr.a + i + 1) for i in range(num_args)]
               
               if callable(func):
                   return func(*args)
           
           elif instr.name == 'RETURN':
               num_returns = instr.b - 1 if instr.b != 0 else len(self.registers) - instr.a
               returns = [self.registers.get(instr.a + i) for i in range(num_returns)]
               return returns[0] if returns else None
           
           elif instr.name == 'FORLOOP':
               idx = self.registers.get(instr.a, 0)
               limit = self.registers.get(instr.a + 1, 0)
               step = self.registers.get(instr.a + 2, 1)
               
               idx += step
               if (step > 0 and idx <= limit) or (step < 0 and idx >= limit):
                   self.registers[instr.a] = idx
                   self.registers[instr.a + 3] = idx
                   pc += instr.sbx
                   continue
           
           elif instr.name == 'FORPREP':
               init = self.registers.get(instr.a, 0)
               limit = self.registers.get(instr.a + 1, 0)
               step = self.registers.get(instr.a + 2, 1)
               
               self.registers[instr.a] = init - step
               pc += instr.sbx
               continue
           
           elif instr.name == 'TFORLOOP':
               func = self.registers.get(instr.a, lambda *x: (None, None))
               state = self.registers.get(instr.a + 1, None)
               control = self.registers.get(instr.a + 2, None)
               
               result = func(state, control)
               if result:
                   self.registers[instr.a + 3] = result[0] if isinstance(result, (list, tuple)) else result
                   self.registers[instr.a + 2] = result[0] if isinstance(result, (list, tuple)) else result
               else:
                   pc += 1
           
           elif instr.name == 'SETLIST':
               table = self.registers.get(instr.a, {})
               if isinstance(table, dict):
                   for i in range(1, instr.b + 1):
                       table[instr.c * 50 + i] = self.registers.get(instr.a + i, None)
           
           elif instr.name == 'CLOSE':
               pass
           
           elif instr.name == 'CLOSURE':
               proto_idx = instr.bx
               self.registers[instr.a] = lambda *args: None
           
           elif instr.name == 'VARARG':
               num_varargs = instr.b - 1 if instr.b != 0 else len(self.virtual_stack)
               for i in range(num_varargs):
                   self.registers[instr.a + i] = self.virtual_stack[i] if i < len(self.virtual_stack) else None
           
           pc += 1
       
       return None
   
   def _simulate_generic(self, data: bytes) -> Any:
       for i, byte in enumerate(data[:1000]):
           self.heap[f'byte_{i}'] = byte
       return None
   
   def set_breakpoint(self, pc: int):
       self.breakpoints.add(pc)
   
   def set_watchpoint(self, var_name: str, condition: Callable):
       self.watchpoints[var_name] = condition
   
   def get_memory_dump(self) -> Dict[str, Any]:
       return {
           'registers': self.registers,
           'stack': self.virtual_stack,
           'heap_size': len(self.heap),
           'call_depth': len(self.call_stack),
           'constants': self.constants,
       }
   
   def dump_strings(self) -> List[str]:
       strings = []
       for v in self.constants.values():
           if isinstance(v, str) and len(v) > 3:
               strings.append(v)
       for v in self.registers.values():
           if isinstance(v, str) and len(v) > 3:
               strings.append(v)
       return strings

class OpcodeBruteforcer:
   def __init__(self):
       self.standard_opcodes = {
           'MOVE': 0, 'LOADK': 1, 'LOADBOOL': 2, 'LOADNIL': 3, 'GETUPVAL': 4,
           'GETGLOBAL': 5, 'GETTABLE': 6, 'SETGLOBAL': 7, 'SETUPVAL': 8, 'SETTABLE': 9,
           'NEWTABLE': 10, 'SELF': 11, 'ADD': 12, 'SUB': 13, 'MUL': 14, 'DIV': 15,
           'MOD': 16, 'POW': 17, 'UNM': 18, 'NOT': 19, 'LEN': 20, 'CONCAT': 21,
           'JMP': 22, 'EQ': 23, 'LT': 24, 'LE': 25, 'TEST': 26, 'TESTSET': 27,
           'CALL': 28, 'TAILCALL': 29, 'RETURN': 30, 'FORLOOP': 31, 'FORPREP': 32,
           'TFORLOOP': 33, 'SETLIST': 34, 'CLOSE': 35, 'CLOSURE': 36, 'VARARG': 37,
       }
       self.behavior_signatures = {
           'LOADK': {'uses_bx': True, 'bx_range': (0, 1000), 'a_range': (0, 50)},
           'ADD': {'uses_b': True, 'uses_c': True, 'b_range': (0, 10), 'c_range': (0, 10)},
           'JMP': {'uses_sbx': True, 'sbx_range': (-100, 100)},
           'CALL': {'uses_a': True, 'uses_b': True, 'a_range': (0, 20), 'b_range': (0, 10)},
           'RETURN': {'uses_a': True, 'uses_b': True, 'a_range': (0, 20), 'b_range': (0, 10)},
       }
       self.learned_mappings = {}
       self.confidence_threshold = 0.7
   
   def bruteforce_opcodes(self, instructions: List[VMInstruction], constants: List[Any]) -> Tuple[Dict[int, str], float]:
       stats = self._collect_statistics(instructions)
       mappings = {}
       
       for opcode, data in stats.items():
           guessed = self._guess_by_behavior(data, constants)
           if guessed:
               mappings[opcode] = guessed
               self.learned_mappings[opcode] = guessed
       
       confidence = len(mappings) / len(stats) if stats else 0.0
       
       if confidence < self.confidence_threshold:
           mappings = self._advanced_heuristic_analysis(instructions, constants, stats)
           confidence = len(mappings) / len(stats) if stats else 0.0
       
       return mappings, confidence
   
   def _collect_statistics(self, instructions: List[VMInstruction]) -> Dict[int, Dict]:
       stats = {}
       for i, instr in enumerate(instructions):
           if instr.opcode not in stats:
               stats[instr.opcode] = {
                   'count': 0, 'a_values': [], 'b_values': [], 'c_values': [],
                   'bx_values': [], 'sbx_values': [], 'next_opcodes': [],
                   'prev_opcodes': [], 'contexts': [],
               }
           
           stats[instr.opcode]['count'] += 1
           stats[instr.opcode]['a_values'].append(instr.a)
           stats[instr.opcode]['b_values'].append(instr.b)
           stats[instr.opcode]['c_values'].append(instr.c)
           stats[instr.opcode]['bx_values'].append(instr.bx)
           stats[instr.opcode]['sbx_values'].append(instr.sbx)
           
           if i > 0:
               stats[instr.opcode]['prev_opcodes'].append(instructions[i-1].opcode)
           if i < len(instructions) - 1:
               stats[instr.opcode]['next_opcodes'].append(instructions[i+1].opcode)
           
           context = self._get_instruction_context(instructions, i)
           stats[instr.opcode]['contexts'].append(context)
       
       return stats
   
   def _get_instruction_context(self, instructions: List[VMInstruction], idx: int) -> Dict:
       context = {
           'before': [],
           'after': [],
           'distance_to_jump': None,
       }
       
       for i in range(max(0, idx-3), idx):
           context['before'].append(instructions[i].opcode)
       
       for i in range(idx+1, min(len(instructions), idx+4)):
           context['after'].append(instructions[i].opcode)
       
       for i in range(idx+1, len(instructions)):
           if instructions[i].name == 'JMP' or instructions[i].opcode == 22:
               context['distance_to_jump'] = i - idx
               break
       
       return context
   
   def _guess_by_behavior(self, data: Dict, constants: List[Any]) -> Optional[str]:
       bx_values = data['bx_values']
       if bx_values and max(bx_values) > 100 and all(v >= 0 for v in bx_values):
           if any(v < len(constants) for v in bx_values if v < 1000):
               return 'LOADK'
       
       sbx_values = data['sbx_values']
       if sbx_values and any(v != 0 for v in sbx_values):
           if max(abs(v) for v in sbx_values) > 10:
               return 'JMP'
       
       b_values = data['b_values']
       c_values = data['c_values']
       if b_values and c_values and max(b_values) < 20 and max(c_values) < 20:
           if data['count'] > 5:
               return 'ADD'
       
       a_values = data['a_values']
       if a_values and any(v == 0 for v in a_values):
           if data.get('next_opcodes') and any(n in [22, 23, 24] for n in data['next_opcodes'][:5]):
               return 'TEST'
       
       return None
   
   def _advanced_heuristic_analysis(self, instructions: List[VMInstruction], constants: List[Any], stats: Dict) -> Dict[int, str]:
       mappings = {}
       
       for opcode, data in stats.items():
           if data['count'] == 1 and any(ctx.get('distance_to_jump') == 1 for ctx in data['contexts']):
               mappings[opcode] = 'RETURN'
               continue
           
           if data['count'] > 10 and all(b == 0 for b in data['b_values']) and all(c == 0 for c in data['c_values']):
               if all(a < 10 for a in data['a_values']):
                   mappings[opcode] = 'LOADNIL'
                   continue
           
           bx_vals = data['bx_values']
           if bx_vals and len(set(bx_vals)) > len(bx_vals) * 0.8:
               if all(0 <= v < len(constants) * 2 for v in bx_vals):
                   mappings[opcode] = 'LOADK'
                   continue
           
           sbx_vals = data['sbx_values']
           if sbx_vals and len([v for v in sbx_vals if v != 0]) > len(sbx_vals) * 0.5:
               if max(abs(v) for v in sbx_vals) > 50:
                   mappings[opcode] = 'JMP'
                   continue
           
           if data.get('next_opcodes'):
               call_candidates = [n for n in data['next_opcodes'] if n in mappings and mappings[n] == 'CALL']
               if len(call_candidates) > len(data['next_opcodes']) * 0.3:
                   mappings[opcode] = 'GETGLOBAL'
                   continue
       
       return mappings
   
   def apply_mapping(self, instructions: List[VMInstruction], mappings: Dict[int, str]) -> List[VMInstruction]:
       for instr in instructions:
           if instr.opcode in mappings:
               instr.name = mappings[instr.opcode]
       return instructions
   
   def save_learned_model(self, filepath: str):
       with open(filepath, 'w') as f:
           json.dump(self.learned_mappings, f)
   
   def load_learned_model(self, filepath: str):
       with open(filepath, 'r') as f:
           self.learned_mappings = json.load(f)

class AnalysisDashboard:
   def __init__(self):
       self.reports = []
       self.threat_levels = {
           'low': 0,
           'medium': 1,
           'high': 2,
           'critical': 3,
       }
   
   def generate_report(self, code: str, deobfuscated: str, metadata: Dict) -> Dict[str, Any]:
       report = {
           'timestamp': time.time(),
           'original_size': len(code),
           'deobfuscated_size': len(deobfuscated),
           'compression_ratio': len(deobfuscated) / len(code) if code else 0,
           'threat_assessment': self._assess_threats(code, deobfuscated),
           'code_quality': self._assess_quality(deobfuscated),
           'security_issues': self._find_security_issues(code),
           'network_indicators': self._extract_network_indicators(code),
           'file_system_indicators': self._extract_fs_indicators(code),
           'obfuscation_techniques': self._identify_techniques(code),
           'recommendations': [],
       }
       
       report['recommendations'] = self._generate_recommendations(report)
       self.reports.append(report)
       return report
   
   def _assess_threats(self, original: str, deobfuscated: str) -> Dict[str, Any]:
       threats = []
       score = 0
       
       malicious_patterns = [
           (r'http[s]?://(?:[a-zA-Z]|[0-9]|[$-_@.&+]|[!*\\(\\),]|(?:%[0-9a-fA-F][0-9a-fA-F]))+', 'external_connection', 2),
           (r'password|token|key|secret|credential', 'credential_access', 3),
           (r'eval\s*\(|loadstring\s*\(|pcall\s*\(\s*load', 'dynamic_execution', 2),
           (r'writefile|readfile|appendfile|delfile', 'file_manipulation', 2),
           (r'setclipboard|toclipboard', 'clipboard_access', 1),
           (r'hookfunction|replaceclosure|newcclosure', 'function_hooking', 2),
           (r'getrawmetatable|setrawmetatable', 'metatable_manipulation', 2),
           (r'debug\.setconstant|debug\.setupvalue', 'debug_manipulation', 3),
           (r'while\s+true\s+do\s*end|for\s+\w+\s+in\s+pairs\s*\(\s*\{\s*\}\s*\)\s+do\s+end', 'denial_of_service', 2),
       ]
       
       for pattern, threat_type, severity in malicious_patterns:
           if re.search(pattern, original, re.IGNORECASE):
               threats.append({'type': threat_type, 'severity': severity})
               score += severity
       
       max_score = len(malicious_patterns) * 3
       threat_level = 'low' if score < 3 else 'medium' if score < 6 else 'high' if score < 9 else 'critical'
       
       return {
           'score': score,
           'max_score': max_score,
           'level': threat_level,
           'threats': threats,
       }
   
   def _assess_quality(self, code: str) -> Dict[str, Any]:
       metrics = {
           'lines_of_code': len(code.split('\n')),
           'functions': len(re.findall(r'function\s+\w+', code)),
           'complexity': len(re.findall(r'if|while|for|repeat', code)),
           'duplication': self._detect_duplication(code),
           'naming_quality': self._assess_naming(code),
       }
       
       quality_score = 100
       quality_score -= metrics['complexity'] * 2
       quality_score -= metrics['duplication'] * 10
       quality_score -= (10 - metrics['naming_quality']) * 5
       
       return {
           'metrics': metrics,
           'score': max(0, quality_score),
           'grade': 'A' if quality_score > 80 else 'B' if quality_score > 60 else 'C' if quality_score > 40 else 'D',
       }
   
   def _detect_duplication(self, code: str) -> int:
       lines = code.split('\n')
       unique_lines = set(lines)
       return len(lines) - len(unique_lines)
   
   def _assess_naming(self, code: str) -> int:
       vars = re.findall(r'local\s+(\w+)', code)
       meaningful = sum(1 for v in vars if len(v) > 2 and not v.startswith('var_') and not v.startswith('v') or len(v) > 3)
       return int((meaningful / len(vars)) * 10) if vars else 0
   
   def _find_security_issues(self, code: str) -> List[Dict]:
       issues = []
       
       checks = [
           (r'loadstring\s*\(\s*[^"\']', 'Unsafe dynamic code execution', 'critical'),
           (r'getfenv\s*\(\s*0\s*\)|setfenv', 'Environment manipulation', 'high'),
           (r'http[s]?://\S+', 'External network request', 'medium'),
           (r'while\s+true\s+do\s*end', 'Infinite loop (DoS)', 'medium'),
           (r'password|api_key|secret\s*=', 'Hardcoded credentials', 'critical'),
           (r'require\s*\(\s*["\']https?://', 'Remote code inclusion', 'critical'),
       ]
       
       for pattern, description, severity in checks:
           for match in re.finditer(pattern, code, re.IGNORECASE):
               issues.append({
                   'line': code[:match.start()].count('\n') + 1,
                   'description': description,
                   'severity': severity,
                   'snippet': match.group(0)[:50],
               })
       
       return issues
   
   def _extract_network_indicators(self, code: str) -> List[str]:
       urls = re.findall(r'http[s]?://(?:[a-zA-Z]|[0-9]|[$-_@.&+]|[!*\\(\\),]|(?:%[0-9a-fA-F][0-9a-fA-F]))+', code)
       domains = re.findall(r'[a-zA-Z0-9][-a-zA-Z0-9]*\.[a-zA-Z]{2,}', code)
       ips = re.findall(r'\b(?:\d{1,3}\.){3}\d{1,3}\b', code)
       
       return list(set(urls + domains + ips))
   
   def _extract_fs_indicators(self, code: str) -> List[str]:
       files = re.findall(r'["\']([^"\']*\.(?:lua|txt|json|xml|dat))["\']', code, re.IGNORECASE)
       paths = re.findall(r'["\']([^"\']*(?:/|\\)[^"\']*)["\']', code)
       
       return list(set(files + paths))
   
   def _identify_techniques(self, code: str) -> List[str]:
       techniques = []
       
       technique_patterns = {
           'base64_encoding': r'[A-Za-z0-9+/]{40,}={0,2}',
           'hex_encoding': r'\\x[0-9A-Fa-f]{2}',
           'xor_encryption': r'bit32\.bxor|~\s*\w+',
           'vm_obfuscation': r'loadstring|load\s*\(',
           'control_flow_flattening': r'while\s+true\s+do\s+if\s+not',
           'string_concatenation': r'\.\.\s*["\']',
           'dead_code': r'if\s+false\s+then|while\s+false\s+do',
           'anti_debug': r'debug\.getinfo|debug\.traceback',
           'bytecode_encoding': r'[\x00-\x08\x0b\x0c\x0e-\x1f]{10,}',
       }
       
       for name, pattern in technique_patterns.items():
           if re.search(pattern, code):
               techniques.append(name)
       
       return techniques
   
   def _generate_recommendations(self, report: Dict) -> List[str]:
       recommendations = []
       
       if report['threat_assessment']['level'] in ['high', 'critical']:
           recommendations.append('Review all external network connections before execution')
           recommendations.append('Run in isolated sandbox environment')
       
       if report['security_issues']:
           recommendations.append('Address all critical and high severity security issues')
       
       if report['code_quality']['score'] < 60:
