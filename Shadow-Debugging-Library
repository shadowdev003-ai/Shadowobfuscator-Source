       self.dashboard = AnalysisDashboard()
       self.decryption_cache = {}
       self.string_dumper = None
   
   def reconstruct(self, code: str, deep_analysis: bool = False, max_iterations: int = 5) -> str:
       original = code
       iteration = 0
       
       while iteration < max_iterations:
           prev_code = code
           
           code = self._extract_vm_bytecode(code)
           code = self._apply_opcode_bruteforce(code)
           code = self._resolve_encrypted_constants(code)
           
           if deep_analysis:
               code = self._dynamic_trace_analysis(code)
               strings = self.sandbox.dump_strings()
               if strings:
                   self.string_dumper = strings
           
           code = self._trace_execution_flow(code)
           code = self._reconstruct_control_flow(code)
           code = self._decompile_to_lua(code)
           code = self._optimize_with_ai(code)
           
           if code == prev_code:
               break
           
           iteration += 1
       
       if deep_analysis:
           report = self.dashboard.generate_report(original, code, {})
           print(f"Analysis Report: {report['threat_assessment']['level']}")
       
       return code
   
   def _extract_vm_bytecode(self, code: str) -> str:
       patterns = [
           (r'loadstring\s*\(\s*(["\'])([A-Za-z0-9+/=]{50,})\1\s*\)', 2),
           (r'load\s*\(\s*function\s*\(\)[^}]*return\s*(["\'])([A-Za-z0-9+/=]{50,})\1\s*end\s*\)', 2),
           (r'local\s+\w+\s*=\s*(["\'])([A-Za-z0-9+/=]{50,})\1[^;]*;?\s*loadstring\s*\(\s*\w+\s*\)', 2),
           (r'decode\s*\(\s*(["\'])([A-Za-z0-9+/=]{50,})\1\s*\)', 2),
           (r'unpack\s*\(\s*(["\'])([A-Za-z0-9+/=]{50,})\1\s*\)', 2),
           (r'buffer\s*\(\s*(["\'])([A-Za-z0-9+/=]{50,})\1\s*\)', 2),
           (r'bytes\s*\(\s*(["\'])([A-Za-z0-9+/=]{50,})\1\s*\)', 2),
           (r'char\s*\(\s*(["\'])([A-Za-z0-9+/=]{50,})\1\s*\)', 2),
           (r'data\s*\(\s*(["\'])([A-Za-z0-9+/=]{50,})\1\s*\)', 2),
           (r'chunk\s*\(\s*(["\'])([A-Za-z0-9+/=]{50,})\1\s*\)', 2),
           (r'__lcode\s*\(\s*(["\'])([A-Za-z0-9+/=]{50,})\1\s*\)', 2),
           (r'__ bytecode\s*\(\s*(["\'])([A-Za-z0-9+/=]{50,})\1\s*\)', 2),
           (r'load\w*\s*\(\s*base64\.decode\s*\(\s*(["\'])([A-Za-z0-9+/=]{50,})\1\s*\)\s*\)', 2),
           (r'load\w*\s*\(\s*decode64\s*\(\s*(["\'])([A-Za-z0-9+/=]{50,})\1\s*\)\s*\)', 2),
           (r'load\w*\s*\(\s*crypt\.base64\.decode\s*\(\s*(["\'])([A-Za-z0-9+/=]{50,})\1\s*\)\s*\)', 2),
       ]
       
       for pattern, group_idx in patterns:
           for match in re.finditer(pattern, code):
               encoded = match.group(group_idx)
               cache_key = hashlib.md5(encoded.encode()).hexdigest()
               
               if cache_key in self.decryption_cache:
                   lua_code = self.decryption_cache[cache_key]
               else:
                   try:
                       decoded = base64.b64decode(encoded)
                       lua_code = self._parse_bytecode_advanced(decoded)
                       if lua_code and len(lua_code) > 50:
                           self.decryption_cache[cache_key] = lua_code
                   except:
                       lua_code = None
               
               if lua_code:
                   code = code.replace(match.group(0), lua_code)
       
       return code
   
   def _parse_bytecode_advanced(self, bytecode: bytes) -> str:
       if bytecode[:4] != b'\x1bLua':
           compressed = self._try_decompress(bytecode)
           if compressed:
               bytecode = compressed
       
       if bytecode[:4] != b'\x1bLua':
           return ""
       
       try:
           instructions, constants, prototypes = self._extract_all_advanced(bytecode)
           
           mappings, confidence = self.bruteforcer.bruteforce_opcodes(instructions, constants)
           if confidence > 0.5:
               instructions = self.bruteforcer.apply_mapping(instructions, mappings)
           
           folded = self._fold_constants_advanced(instructions, constants)
           lua = self._generate_lua_advanced(folded, constants, prototypes)
           return lua
       except Exception as e:
           return f"-- Parse error: {str(e)[:100]}"
   
   def _try_decompress(self, data: bytes) -> Optional[bytes]:
       methods = [
           zlib.decompress,
           lambda x: zlib.decompress(x, -15),
           lambda x: zlib.decompress(x, 15),
           lambda x: zlib.decompress(x, 31),
       ]
       
       for decompress in methods:
           try:
               result = decompress(data)
               if b'\x1bLua' in result:
                   return result
           except:
               continue
       
       xor_keys = [0x55, 0xAA, 0x12, 0x34, 0x78, 0x9A, 0xBC, 0xDE, 0xF0, 0x0F, 0x33, 0x66, 0x99, 0xCC]
       for xor_key in xor_keys:
           try:
               xored = bytes(b ^ xor_key for b in data)
               if b'\x1bLua' in xored:
                   return xored
           except:
               continue
       
       return None
   
   def _extract_all_advanced(self, bytecode: bytes) -> Tuple[List[VMInstruction], List[Any], List[Any]]:
       pos = 12
       
       def read_int(size: int) -> int:
           nonlocal pos
           val = int.from_bytes(bytecode[pos:pos+size], 'little')
           pos += size
           return val
       
       def read_size_t() -> int:
           return read_int(4)
       
       def read_instruction() -> int:
           nonlocal pos
           val = int.from_bytes(bytecode[pos:pos+4], 'little')
           pos += 4
           return val
       
       def read_number() -> float:
           nonlocal pos
           return struct.unpack('<d', bytecode[pos:pos+8])[0]
       
       def read_string() -> str:
           nonlocal pos
           size = read_size_t()
           if size == 0:
               return ""
           result = bytecode[pos:pos+size-1].decode('utf-8', errors='ignore')
           pos += size
           return result
       
       source_len = read_size_t()
       pos += source_len
       
       line_defined = read_int(4)
       last_line_defined = read_int(4)
       num_upvalues = bytecode[pos]
       pos += 1
       num_params = bytecode[pos]
       pos += 1
       is_vararg = bytecode[pos]
       pos += 1
       max_stack_size = bytecode[pos]
       pos += 1
       
       num_instr = read_int(4)
       instructions = []
       
       for _ in range(num_instr):
           instr = read_instruction()
           opcode = instr & 0x3F
           a = (instr >> 6) & 0xFF
           c = (instr >> 14) & 0x1FF
           b = (instr >> 23) & 0x1FF
           bx = (instr >> 14) & 0x3FFFF
           sbx = bx - 131071
           
           instructions.append(VMInstruction(opcode, a, b, c, bx, sbx, instr))
       
       num_const = read_int(4)
       constants = []
       
       for _ in range(num_const):
           const_type = bytecode[pos]
           pos += 1
           
           if const_type == 0:
               constants.append(None)
           elif const_type == 1:
               constants.append(bytecode[pos] != 0)
               pos += 1
           elif const_type == 3:
               constants.append(read_number())
           elif const_type == 4:
               constants.append(read_string())
       
       num_protos = read_int(4)
       prototypes = []
       
       for _ in range(num_protos):
           proto_size = read_int(4)
           if proto_size > 0:
               proto_data = bytecode[pos:pos+proto_size]
               prototypes.append(proto_data)
               pos += proto_size
       
       return instructions, constants, prototypes
   
   def _apply_opcode_bruteforce(self, code: str) -> str:
       vm_patterns = [
           r'local\s+\w+\s*=\s*\{\s*(\d+\s*,\s*)*\d+\s*\}',
           r'local\s+\w+\s*=\s*function\s*\([^)]*\)[^e]*end',
           r'while\s+\w+\s*<=\s*\w+\           s+do\s+local\s+\w+\s*=\s*\w+\[\w+\]',
       ]
       
       for pattern in vm_patterns:
           matches = list(re.finditer(pattern, code))
           if len(matches) > 5:
               code = self._attempt_vm_reconstruction(code, matches)
       
       return code
   
   def _attempt_vm_reconstruction(self, code: str, matches: List) -> str:
       return code
   
   def _fold_constants_advanced(self, instructions: List[VMInstruction], constants: List[Any]) -> List[VMInstruction]:
       regs = {}
       optimized = []
       
       for instr in instructions:
           if instr.name == 'LOADK':
               regs[instr.a] = constants[instr.bx] if instr.bx < len(constants) else None
               optimized.append(instr)
           
           elif instr.name in ['ADD', 'SUB', 'MUL', 'DIV', 'MOD', 'POW']:
               if instr.b in regs and instr.c in regs:
                   left, right = regs[instr.b], regs[instr.c]
                   if isinstance(left, (int, float)) and isinstance(right, (int, float)):
                       ops = {'ADD': operator.add, 'SUB': operator.sub, 'MUL': operator.mul, 
                              'DIV': operator.truediv, 'MOD': operator.mod, 'POW': operator.pow}
                       result = ops[instr.name](left, right)
                       regs[instr.a] = result
                       new_instr = VMInstruction(1, instr.a, 0, 0, 0, 0, instr.original)
                       new_instr.resolved_val = result
                       new_instr.folded = True
                       optimized.append(new_instr)
                       continue
               optimized.append(instr)
           
           elif instr.name == 'UNM':
               if instr.b in regs:
                   val = regs[instr.b]
                   if isinstance(val, (int, float)):
                       result = -val
                       regs[instr.a] = result
                       new_instr = VMInstruction(1, instr.a, 0, 0, 0, 0, instr.original)
                       new_instr.resolved_val = result
                       new_instr.folded = True
                       optimized.append(new_instr)
                       continue
               optimized.append(instr)
           
           elif instr.name == 'NOT':
               if instr.b in regs:
                   val = regs[instr.b]
                   result = not val
                   regs[instr.a] = result
                   new_instr = VMInstruction(1, instr.a, 0, 0, 0, 0, instr.original)
                   new_instr.resolved_val = result
                   new_instr.folded = True
                   optimized.append(new_instr)
                   continue
               optimized.append(instr)
           
           elif instr.name == 'LEN':
               if instr.b in regs:
                   val = regs[instr.b]
                   if isinstance(val, (str, list, dict)):
                       result = len(val)
                       regs[instr.a] = result
                       new_instr = VMInstruction(1, instr.a, 0, 0, 0, 0, instr.original)
                       new_instr.resolved_val = result
                       new_instr.folded = True
                       optimized.append(new_instr)
                       continue
               optimized.append(instr)
           
           else:
               optimized.append(instr)
       
       return optimized
   
   def _generate_lua_advanced(self, instructions: List[VMInstruction], constants: List[Any], prototypes: List[Any] = None) -> str:
       lines = ['-- VMR Advanced Decompiled', 'local function vm_main(...)']
       lines.append('    local R = {}')
       lines.append('    local K = {}')
       
       for i, c in enumerate(constants):
           if isinstance(c, str) and len(c) > 50:
               lines.append(f'    K[{i}] = "{c[:50]}..."')
           else:
               lines.append(f'    K[{i}] = {repr(c)}')
       
       label_map = {}
       for i, instr in enumerate(instructions):
           if instr.name == 'JMP':
               target = i + 1 + instr.sbx
               if target not in label_map:
                   label_map[target] = f'L{len(label_map)}'
       
       for i, instr in enumerate(instructions):
           if i in label_map:
               lines.append(f'    ::{label_map[i]}::')
           
           line = f'    -- [{i}] {instr.name}'
           
           if instr.folded and instr.resolved_val is not None:
               line += f'\n    R[{instr.a}] = {repr(instr.resolved_val)}'
           elif instr.name == 'LOADK':
               line += f'\n    R[{instr.a}] = K[{instr.bx}]'
           elif instr.name == 'LOADBOOL':
               line += f'\n    R[{instr.a}] = {str(instr.b != 0).lower()}'
           elif instr.name == 'LOADNIL':
               line += f'\n    R[{instr.a}] = nil'
           elif instr.name in ['ADD', 'SUB', 'MUL', 'DIV', 'MOD', 'POW']:
               line += f'\n    R[{instr.a}] = R[{instr.b}] {instr.name} R[{instr.c}]'
           elif instr.name == 'UNM':
               line += f'\n    R[{instr.a}] = -R[{instr.b}]'
           elif instr.name == 'NOT':
               line += f'\n    R[{instr.a}] = not R[{instr.b}]'
           elif instr.name == 'LEN':
               line += f'\n    R[{instr.a}] = #R[{instr.b}]'
           elif instr.name == 'CONCAT':
               line += f'\n    R[{instr.a}] = R[{instr.b}] .. R[{instr.c}]'
           elif instr.name == 'MOVE':
               line += f'\n    R[{instr.a}] = R[{instr.b}]'
           elif instr.name == 'GETGLOBAL':
               c = constants[instr.bx] if instr.bx < len(constants) else 'unknown'
               line += f'\n    R[{instr.a}] = _G["{c}"]'
           elif instr.name == 'SETGLOBAL':
               c = constants[instr.bx] if instr.bx < len(constants) else 'unknown'
               line += f'\n    _G["{c}"] = R[{instr.a}]'
           elif instr.name == 'GETTABLE':
               line += f'\n    R[{instr.a}] = R[{instr.b}][R[{instr.c}]]'
           elif instr.name == 'SETTABLE':
               line += f'\n    R[{instr.a}][R[{instr.b}]] = R[{instr.c}]'
           elif instr.name == 'NEWTABLE':
               line += f'\n    R[{instr.a}] = {{}}'
           elif instr.name == 'SELF':
               line += f'\n    R[{instr.a + 1}] = R[{instr.b}]\n    R[{instr.a}] = R[{instr.b}][K[{instr.c}]]'
           elif instr.name == 'CALL':
               if instr.b == 0:
                   line += f'\n    R[{instr.a}] = R[{instr.a}](unpack(R, {instr.a + 1}))'
               elif instr.b == 1:
                   line += f'\n    R[{instr.a}] = R[{instr.a}]()'
               else:
                   args = ', '.join([f'R[{instr.a + j + 1}]' for j in range(instr.b - 1)])
                   line += f'\n    R[{instr.a}] = R[{instr.a}]({args})'
           elif instr.name == 'RETURN':
               if instr.b == 0:
                   line += f'\n    return unpack(R, {instr.a})'
               elif instr.b == 1:
                   line += f'\n    return'
               else:
                   rets = ', '.join([f'R[{instr.a + j}]' for j in range(instr.b - 1)])
                   line += f'\n    return {rets}'
           elif instr.name == 'JMP':
               target = i + 1 + instr.sbx
               if target in label_map:
                   line += f'\n    goto {label_map[target]}'
               else:
                   line += f'\n    goto pc_{target}'
           elif instr.name in ['EQ', 'LT', 'LE']:
               op = {'EQ': '==', 'LT': '<', 'LE': '<='}[instr.name]
               line += f'\n    if R[{instr.b}] {op} R[{instr.c}] then goto L_skip end'
           elif instr.name == 'TEST':
               line += f'\n    if not R[{instr.a}] then goto L_skip end'
           elif instr.name == 'TESTSET':
               line += f'\n    if R[{instr.b}] then R[{instr.a}] = R[{instr.b}] else goto L_skip end'
           elif instr.name == 'FORLOOP':
               target = i + 1 + instr.sbx
               label = label_map.get(target, f'L{target}')
               line += f'\n    R[{instr.a}] = R[{instr.a}] + R[{instr.a + 2}]\n    if R[{instr.a}] <= R[{instr.a + 1}] then\n        R[{instr.a + 3}] = R[{instr.a}]\n        goto {label}\n    end'
           elif instr.name == 'FORPREP':
               target = i + 1 + instr.sbx
               label = label_map.get(target, f'L{target}')
               line += f'\n    R[{instr.a}] = R[{instr.a}] - R[{instr.a + 2}]\n    goto {label}'
           elif instr.name == 'CLOSURE':
               line += f'\n    R[{instr.a}] = function(...) return nil end'
           elif instr.name == 'VARARG':
               if instr.b == 0:
                   line += f'\n    R[{instr.a}] = arg'
               else:
                   for j in range(instr.b - 1):
                       line += f'\n    R[{instr.a + j}] = arg[{j + 1}]'
           
           lines.append(line)
       
       lines.append('end')
       lines.append('return vm_main')
       return '\n'.join(lines)
   
   def _dynamic_trace_analysis(self, code: str) -> str:
       func_patterns = [
           r'local\s+(\w+)\s*=\s*function\s*\(([^)]*)\)([^e][^n][^d].*?)end',
           r'function\s+(\w+)\s*\(([^)]*)\)([^e][^n][^d].*?)end',
           r'(\w+)\s*=\s*function\s*\(([^)]*)\)([^e][^n][^d].*?)end',
       ]
       
       for pattern in func_patterns:
           for match in re.finditer(pattern, code, re.DOTALL):
               func_name = match.group(1)
               func_body = match.group(3)
               
               if any(x in func_body.lower() for x in ['string.char', 'xor', 'decode', 'decrypt', 'unpack']):
                   result = self.sandbox.simulate_call(func_body.encode(), [1, 2, 3])
                   if result['success'] and result['trace']:
                       resolved = self._resolve_from_trace(result['trace'])
                       if resolved and len(str(resolved)) > 10:
                           code = code.replace(match.group(0), f'local {func_name} = function(...) return {repr(resolved)} end', 1)
       
       return code
   
   def _resolve_from_trace(self, trace: List[Dict]) -> Optional[str]:
       for entry in trace:
           if 'result' in entry:
               if isinstance(entry['result'], str) and len(entry['result']) > 5:
                   return entry['result']
               if isinstance(entry['result'], (int, float)):
                   return str(entry['result'])
       return None
   
   def _resolve_encrypted_constants(self, code: str) -> str:
       xor_keys = [0x55, 0xAA, 0x12, 0x34, 0x78, 0x9A, 0xBC, 0xDE, 0xF0, 0x0F, 0x33, 0x66, 0x99, 0xCC, 0x11, 0x22, 0x44, 0x88, 0x77, 0xEE, 0x00, 0xFF]
       
       hex_pattern = r'0x([0-9A-Fa-f]{2,})'
       for match in re.finditer(hex_pattern, code):
           hex_str = match.group(1)
           if len(hex_str) % 2 == 0 and len(hex_str) > 4:
               try:
                   decoded = bytes.fromhex(hex_str).decode('utf-8', errors='ignore')
                   if all(32 <= ord(c) < 127 for c in decoded) and len(decoded) > 3:
                       code = code.replace(match.group(0), f'"{decoded}"', 1)
               except:
                   pass
       
       b64_pattern = r'["\']([A-Za-z0-9+/=]{20,})["\']'
       for match in re.finditer(b64_pattern, code):
           encoded = match.group(1)
           try:
               decoded = base64.b64decode(encoded).decode('utf-8', errors='ignore')
               if all(32 <= ord(c) < 127 for c in decoded) and len(decoded) > 5:
                   code = code.replace(match.group(0), f'"{decoded}"', 1)
                   continue
           except:
               pass
           
           for key in xor_keys:
               try:
                   xored = ''.join(chr(ord(c) ^ key) for c in encoded)
                   if all(32 <= ord(c) < 127 for c in xored) and len(xored) > 5:
                       code = code.replace(match.group(0), f'"{xored}"', 1)
                       break
               except:
                   continue
       
       char_pattern = r'string\.char\s*\(([\d\s,]+)\)'
       for match in re.finditer(char_pattern, code):
           try:
               nums = [int(x.strip()) for x in match.group(1).split(',') if x.strip()]
               decoded = ''.join(chr(n) for n in nums if 0 <= n < 256)
               if all(32 <= ord(c) < 127 for c in decoded) and len(decoded) > 3:
                   code = code.replace(match.group(0), f'"{decoded}"', 1)
           except:
               pass
       
       return code
   
   def _trace_execution_flow(self, code: str) -> str:
       state_machine_pattern = r'while\s+(\w+)\s*<\s*(\d+)\s*do\s+if\s+\1\s*==\s*(\d+)\s*then'
       matches = list(re.finditer(state_machine_pattern, code))
       
       if len(matches) > 3:
           blocks = []
           var = matches[0].group(1)
           
           for i, match in enumerate(matches):
               state = match.group(3)
               end_pos = matches[i+1].start() if i+1 < len(matches) else len(code)
               block = code[match.start():end_pos]
               
               block_clean = re.sub(rf'if\s+{var}\s*==\s*{state}\s+then\s*', '', block)
               block_clean = re.sub(r'\s*end\s*$', '', block_clean)
               block_clean = re.sub(rf'{var}\s*=\s*{int(state)+1}', '', block_clean)
               block_clean = re.sub(rf'while\s+{var}\s*<\s*\d+\s*do', '', block_clean)
               block_clean = re.sub(r'end\s*$', '', block_clean)
               
               blocks.append(block_clean.strip())
           
           return '\n\n'.join(blocks)
       
       return code
   
   def _reconstruct_control_flow(self, code: str) -> str:
       patterns = [
           (r'while\s+true\s+do\s+if\s+not\s*\((.*?)\)\s+then\s+break\s+end', r'while \1 do'),
           (r'repeat\s+(.*?)\s+until\s+not\s*\((.*?)\)', r'while not (\2) do \1 end'),
           (r'if\s*\((.*?)\)\s*then\s*(.*?)\s*else\s*break\s+end', r'if not (\1) then break end \2'),
           (r'while\s+false\s+do.*?end', ''),
           (r'if\s+true\s+then\s+else\s+end', ''),
           (r'if\s+false\s+then\s+else\s+end', ''),
       ]
       
       for pattern, replacement in patterns:
           code = re.sub(pattern, replacement, code, flags=re.DOTALL)
       
       code = re.sub(r'::\w+::', '', code)
       code = re.sub(r'goto\s+\w+', '', code)
       
       return code
   
   def _decompile_to_lua(self, code: str) -> str:
       return code
   
   def _optimize_with_ai(self, code: str) -> str:
       return self.ai.generate(code, 'vm_decode')

class CodeBeautification:
   def __init__(self):
       self.ai = ShadowAIEngine()
       self.indent_unit = '    '
   
   def beautify(self, code: str, aggressive: bool = False) -> str:
       code = self._remove_junk(code)
       code = self._normalize_whitespace(code)
       code = self._restructure_blocks(code)
       code = self._optimize_names(code)
       code = self._smart_indent(code)
       
       if aggressive:
           code = self.ai.generate(code, 'beautify')
       
       return code
   
   def _remove_junk(self, code: str) -> str:
       junk_patterns = [
           r'local\s+\w+\s*=\s*\d+\s*[\+\-]\s*\d+[^;]*',
           r'\blocal\s+\w+\s*=\s*\w+\s*;?\s*\n',
           r'local\s+\w+\s*=\s*\{\s*\}',
           r'local\s+\w+\s*=\s*""',
           r'local\s+\w+\s*=\s*0\s*;?',
           r'if\s+true\s+then\s+else\s+end',
           r'if\s+false\s+then\s+else\s+end',
           r'while\s+false\s+do.*?end',
           r'assert\s*\(\s*false[^)]*\)',
           r'error\s*\(\s*["\'][^"\']*["\']\s*\)',
           r'debug\.getinfo\s*\([^)]*\)',
           r'debug\.traceback\s*\([^)]*\)',
           r'pcall\s*\(\s*function\s*\(\)\s*error\s*\([^)]*\)\s*end\s*\)',
           r'local\s+\w+\s*=\s*function\s*\(\)\s*return\s+nil\s+end',
           r'\(\s*function\s*\(\)[^}]*end\s*\)\s*\(\s*\)',
       ]
       
       for pattern in junk_patterns:
           code = re.sub(pattern, '', code, flags=re.DOTALL)
       
       code = self._remove_unused_vars(code)
       code = self._remove_dead_stores(code)
       return code
   
   def _remove_unused_vars(self, code: str) -> str:
       local_pattern = r'local\s+(\w+)'
       locals_found = re.findall(local_pattern, code)
       
       for var in locals_found:
           usages = len(re.findall(rf'\b{var}\b', code))
           if usages <= 1:
               code = re.sub(rf'local\s+{var}\s*=\s*[^;\n]*[;\n]?', '', code)
       
       return code
   
   def _remove_dead_stores(self, code: str) -> str:
       pattern = r'(\w+)\s*=\s*([^;\n]+)[;\n]\s*\1\s*=\s*'
       code = re.sub(pattern, r'\1 = ', code)
       return code
   
   def _normalize_whitespace(self, code: str) -> str:
       code = re.sub(r'[ \t]+', ' ', code)
       code = re.sub(r';\s*', '\n', code)
       code = re.sub(r'\r\n', '\n', code)
       code = re.sub(r'\n{3,}', '\n\n', code)
       return code
   
   def _restructure_blocks(self, code: str) -> str:
       keywords = {
           'function': '\nfunction ',
           'local function': '\nlocal function ',
           'if ': '\nif ',
           'elseif ': '\nelseif ',
           'else': '\nelse\n',
           'while ': '\nwhile ',
           'for ': '\nfor ',
           'repeat': '\nrepeat\n',
           'until ': '\nuntil ',
           'return': '\nreturn ',
       }
       
       for old, new in keywords.items():
           code = code.replace(old, new)
       
       code = code.replace('end', '\nend\n')
       code = re.sub(r'\n\s*\n+', '\n\n', code)
       return code
   
   def _optimize_names(self, code: str) -> str:
       common_patterns = {
           r'local\s+(\w+)\s*=\s*game:GetService\("Players"\)': 'local Players',
           r'local\s+(\w+)\s*=\s*game:GetService\("Workspace"\)': 'local Workspace',
           r'local\s+(\w+)\s*=\s*game:GetService\("ReplicatedStorage"\)': 'local ReplicatedStorage',
           r'local\s+(\w+)\s*=\s*game\.Players\.LocalPlayer': 'local LocalPlayer',
           r'local\s+(\w+)\s*=\s*LocalPlayer\.Character': 'local Character',
       }
       
       for pattern, replacement in common_patterns.items():
           code = re.sub(pattern, replacement, code)
       
       return code
   
   def _smart_indent(self, code: str) -> str:
       lines = code.split('\n')
       result = []
       indent = 0
       
       for line in lines:
           line = line.strip()
           if not line:
               continue
           
           if any(line.startswith(x) for x in ['end', 'until', 'else', 'elseif']):
               indent = max(0, indent - 1)
           
           result.append(self.indent_unit * indent + line)
           
           if any(x in line for x in ['function', 'then', 'do', 'repeat', '{']) and not line.startswith('end'):
               if 'end' not in line:
                   indent += 1
           
           if line.startswith('end') or line.startswith('until'):
               indent = max(0, indent - 1)
       
       return '\n'.join(result)

class ShadowAntiTamper:
   def __init__(self):
