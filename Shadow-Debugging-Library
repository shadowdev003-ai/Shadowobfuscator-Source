class LocalLLMManager:
   def __init__(self):
       self.model_path = None
       self.process = None
       self.available = False
       self._check_availability()
   
   def _check_availability(self):
       try:
           result = subprocess.run(['ollama', 'list'], capture_output=True, text=True, timeout=5)
           if result.returncode == 0:
               self.available = True
               models = result.stdout.strip().split('\n')
               if len(models) > 1:
                   self.model_path = models[1].split()[0]
       except:
           pass
   
   def generate(self, prompt: str, max_tokens: int = 4000) -> Optional[str]:
       if not self.available:
           return None
       
       try:
           result = subprocess.run(
               ['ollama', 'run', self.model_path, prompt[:2000]],
               capture_output=True,
               text=True,
               timeout=60
           )
           if result.returncode == 0:
               return result.stdout.strip()
       except:
           pass
       
       return None

class ShadowAIEngine:
   def __init__(self):
       self.endpoints = [
           {'url': 'https://text.pollinations.ai/{prompt}?model=openai', 'type': 'pollinations'},
           {'url': 'https://api.deepai.org/api/text-generator', 'type': 'deepai', 'key': 'quickstart-QUdJIGlzIGNvbWluZy4gTmljZSB0byBtZWV0IHlvdSE='},
           {'url': 'https://api-inference.huggingface.co/models/bigcode/starcoder', 'type': 'huggingface', 'key': None},
       ]
       self.local_llm = LocalLLMManager()
       self.cache = {}
       self.request_history = []
       self.fallback_chain = ['local', 'pollinations', 'deepai', 'huggingface']
   
   def generate(self, prompt: str, mode: str = 'deobfuscate', max_tokens: int = 4000, prefer_local: bool = False) -> str:
       if prefer_local and self.local_llm.available:
           local_result = self.local_llm.generate(prompt, max_tokens)
           if local_result:
               return local_result
       
       cache_key = hashlib.md5(f"{mode}:{prompt[:500]}".encode()).hexdigest()
       if cache_key in self.cache:
           return self.cache[cache_key]
       
       formatted_prompt = self._format_prompt(prompt, mode)
       results = []
       
       for source in self.fallback_chain:
           if source == 'local':
               if self.local_llm.available:
                   result = self.local_llm.generate(formatted_prompt, max_tokens)
                   if result:
                       results.append(('local', result))
           else:
               endpoint = next((e for e in self.endpoints if e['type'] == source), None)
               if endpoint:
                   try:
                       result = self._try_endpoint(endpoint, formatted_prompt, max_tokens)
                       if result and len(result) > 100:
                           results.append((source, result))
                   except:
                       continue
       
       best_result = self._select_best_result([r[1] for r in results], mode)
       if best_result:
           self.cache[cache_key] = best_result
           return best_result
       
       return prompt
   
   def _format_prompt(self, prompt: str, mode: str) -> str:
       templates = {
           'deobfuscate': f"Deobfuscate this Lua code completely. Remove all junk, restore original logic, return clean code only:\n\n{prompt}",
           'analyze': f"Analyze this obfuscated Lua code. Identify obfuscation techniques, VM patterns, encryption methods:\n\n{prompt}",
           'optimize': f"Optimize this Lua code for maximum performance. Remove redundancies, simplify expressions:\n\n{prompt}",
           'beautify': f"Beautify this Lua code perfectly. Fix indentation, add proper spacing, make it readable:\n\n{prompt}",
           'vm_decode': f"Decode this Lua VM bytecode. Reconstruct original opcodes, resolve constants, return decompiled code:\n\n{prompt}",
           'security': f"Analyze security risks. Find backdoors, malicious patterns, data exfiltration attempts:\n\n{prompt}",
           'rename': f"Rename all variables in this Lua code to meaningful names based on context. Return only the renamed code:\n\n{prompt}",
       }
       return templates.get(mode, templates['deobfuscate'])
   
   def _try_endpoint(self, endpoint: Dict, prompt: str, max_tokens: int) -> Optional[str]:
       if endpoint['type'] == 'pollinations':
           url = endpoint['url'].format(prompt=requests.utils.quote(prompt[:3000]))
           res = requests.get(url, timeout=45)
           if res.status_code == 200:
               return self._clean_response(res.text)
       
       elif endpoint['type'] == 'deepai':
           res = requests.post(
               endpoint['url'],
               headers={'api-key': endpoint['key']},
               data={'text': prompt[:3000]},
               timeout=60
           )
           if res.status_code == 200:
               data = res.json()
               return self._clean_response(data.get('output', ''))
       
       elif endpoint['type'] == 'huggingface':
           res = requests.post(
               endpoint['url'],
               headers={'Authorization': f'Bearer {endpoint["key"]}'} if endpoint['key'] else {},
               json={'inputs': prompt[:2000], 'parameters': {'max_new_tokens': max_tokens}},
               timeout=120
           )
           if res.status_code == 200:
               data = res.json()
               return self._clean_response(data[0].get('generated_text', ''))
       
       return None
   
   def _clean_response(self, text: str) -> str:
       text = re.sub(r'```(?:lua)?\n(.*?)\n```', r'\1', text, flags=re.DOTALL)
       text = re.sub(r'  ', '', text, flags=re.DOTALL)
       text = re.sub(r'\[思考开始\].*?\[思考结束\]', '', text, flags=re.DOTALL)
       text = re.sub(r'Here is the (deobfuscated|cleaned|optimized) code:?\s*', '', text, flags=re.IGNORECASE)
       return text.strip()
   
   def _select_best_result(self, results: List[str], mode: str) -> Optional[str]:
       if not results:
           return None
       
       scored = []
       for result in results:
           score = 0
           if mode == 'deobfuscate':
               score += len(re.findall(r'function\s+\w+\s*\(', result)) * 10
               score += len(re.findall(r'local\s+\w+\s*=', result)) * 5
               score -= len(re.findall(r'[A-Za-z0-9+/]{20,}={0,2}', result)) * 20
               score -= result.count('[') + result.count(']')
           elif mode == 'beautify':
               score += result.count('\n') * 2
               score += len(re.findall(r'^\s{4}', result, re.MULTILINE)) * 5
               score -= len(re.findall(r'[ \t]+\n', result)) * 10
           elif mode == 'vm_decode':
               score += len(re.findall(r'--\s*\[\d+\]', result)) * 5
               score += len(re.findall(r'local\s+R\s*\[', result)) * 3
           
           score += min(len(result) / 100, 50)
           scored.append((score, result))
       
       scored.sort(reverse=True)
       return scored[0][1] if scored else None
   
   def multi_pass(self, code: str, passes: int = 3, mode: str = 'deobfuscate') -> str:
       current = code
       for i in range(passes):
           current = self.generate(current, mode)
           time.sleep(0.3)
       return current

class SafeEvaluator:
   def __init__(self):
       self.allowed_ops = {
           ast.Add: operator.add, ast.Sub: operator.sub, ast.Mult: operator.mul,
           ast.Div: operator.truediv, ast.FloorDiv: operator.floordiv,
           ast.Mod: operator.mod, ast.Pow: operator.pow,
           ast.USub: operator.neg, ast.UAdd: operator.pos,
           ast.BitAnd: operator.and_, ast.BitOr: operator.or_,
           ast.BitXor: operator.xor, ast.LShift: operator.lshift,
           ast.RShift: operator.rshift, ast.Invert: operator.invert,
       }
       self.allowed_names = {
           'abs': abs, 'max': max, 'min': min, 'pow': pow, 'round': round,
           'sum': sum, 'len': len, 'ord': ord, 'chr': chr,
           'hex': hex, 'bin': bin, 'oct': oct,
           'math': math, 'string': string,
       }
   
   def eval(self, expr: str) -> Any:
       try:
           tree = ast.parse(expr, mode='eval')
           return self._eval_node(tree.body)
       except:
           return expr
   
   def _eval_node(self, node: ast.AST) -> Any:
       if isinstance(node, ast.Num):
           return node.n
       elif isinstance(node, ast.Constant):
           return node.value
       elif isinstance(node, ast.BinOp):
           left = self._eval_node(node.left)
           right = self._eval_node(node.right)
           op_type = type(node.op)
           if op_type in self.allowed_ops:
               return self.allowed_ops[op_type](left, right)
           raise ValueError(f"Unsupported operator: {op_type}")
       elif isinstance(node, ast.UnaryOp):
           operand = self._eval_node(node.operand)
           op_type = type(node.op)
           if op_type in self.allowed_ops:
               return self.allowed_ops[op_type](operand)
           raise ValueError(f"Unsupported unary: {op_type}")
       elif isinstance(node, ast.Call):
           if isinstance(node.func, ast.Name) and node.func.id in self.allowed_names:
               args = [self._eval_node(arg) for arg in node.args]
               return self.allowed_names[node.func.id](*args)
           raise ValueError(f"Unsupported call: {node.func}")
       elif isinstance(node, ast.Name):
           if node.id in self.allowed_names:
               return self.allowed_names[node.id]
           raise ValueError(f"Unknown: {node.id}")
       elif isinstance(node, ast.Subscript):
           value = self._eval_node(node.value)
           slice_val = self._eval_node(node.slice)
           return value[slice_val]
       elif isinstance(node, ast.Attribute):
           value = self._eval_node(node.value)
           return getattr(value, node.attr)
       elif isinstance(node, (ast.Tuple, ast.List)):
           return [self._eval_node(elt) for elt in node.elts]
       else:
           raise ValueError(f"Unsupported: {type(node)}")

