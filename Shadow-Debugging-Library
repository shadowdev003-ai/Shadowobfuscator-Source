class ShadowCryptography:
   def __init__(self):
       self.common_keys = [
           b'key', b'secret', b'password', b'admin', b'root',
           b'123456', b'qwerty', b'letmein', b'welcome', b'password123',
           b'lua', b'obfuscate', b'decrypt', b'encrypt', b'xor',
           b'0x55', b'0xAA', b'0x12', b'0x34', b'0x78',
       ]
       self.xor_keys = [0x55, 0xAA, 0x12, 0x34, 0x78, 0x9A, 0xBC, 0xDE, 0xF0, 0x0F]
   
   def decrypt_xor(self, data: bytes, key: Union[int, bytes]) -> bytes:
       if isinstance(key, int):
           return bytes(b ^ key for b in data)
       return bytes(b ^ key[i % len(key)] for i, b in enumerate(data))
   
   def try_decrypt(self, data: bytes) -> List[Tuple[str, bytes]]:
       results = []
       
       for key in self.xor_keys:
           decrypted = self.decrypt_xor(data, key)
           if self._is_valid_lua(decrypted):
               results.append((f'xor_{hex(key)}', decrypted))
       
       for key in self.common_keys:
           decrypted = self.decrypt_xor(data, key)
           if self._is_valid_lua(decrypted):
               results.append((f'xor_key_{key.decode()}', decrypted))
       
       try:
           decompressed = zlib.decompress(data)
           if self._is_valid_lua(decompressed):
               results.append(('zlib', decompressed))
       except:
           pass
       
       try:
           decompressed = zlib.decompress(data, -15)
           if self._is_valid_lua(decompressed):
               results.append(('zlib_raw', decompressed))
       except:
           pass
       
       try:
           decoded = base64.b64decode(data)
           if self._is_valid_lua(decoded):
               results.append(('base64', decoded))
       except:
           pass
       
       return results
   
   def _is_valid_lua(self, data: bytes) -> bool:
       if data.startswith(b'\x1bLua'):
           return True
       try:
           text = data.decode('utf-8', errors='ignore')
           lua_indicators = ['function', 'local', 'end', 'if', 'then', 'else', 'while', 'for', 'do', 'return']
           score = sum(1 for ind in lua_indicators if ind in text)
           return score >= 3 and len(text) > 50
       except:
           return False
   
   def extract_strings(self, data: bytes) -> List[str]:
       strings = []
       current = b''
       
       for byte in data:
           if 32 <= byte < 127:
               current += bytes([byte])
           else:
               if len(current) >= 4:
                   strings.append(current.decode('utf-8', errors='ignore'))
               current = b''
       
       if len(current) >= 4:
           strings.append(current.decode('utf-8', errors='ignore'))
       
       return strings

class ShadowHeuristicEngine:
   def __init__(self):
       self.ai = ShadowAIEngine()
       self.patterns = {
           'string_concat': r'(["\'][^"\']*["\'])\s*\.\.\s*(["\'][^"\']*["\'])',
           'table_concat': r'table\.concat\s*\(\s*\{([^}]*)\}\s*,\s*["\']?[^"\')]*["\']?\)',
           'string_char': r'string\.char\s*\(([^)]+)\)',
           'string_byte': r'string\.byte\s*\(([^)]+)\)',
           'bit_xor': r'bit32\.bxor\s*\(([^)]+)\)',
           'bit_and': r'bit32\.band\s*\(([^)]+)\)',
           'bit_or': r'bit32\.bor\s*\(([^)]+)\)',
           'bit_not': r'bit32\.bnot\s*\(([^)]+)\)',
       }
   
   def analyze(self, code: str) -> Dict[str, Any]:
       results = {
           'entropy': self._calculate_entropy(code),
           'patterns_found': {},
           'suspicious_constructs': [],
           'complexity_score': 0,
       }
       
       for name, pattern in self.patterns.items():
           matches = list(re.finditer(pattern, code))
           if matches:
               results['patterns_found'][name] = len(matches)
       
       suspicious = [
           (r'loadstring\s*\(\s*function', 'dynamic_code_loading'),
           (r'getfenv\s*\(\s*0\s*\)', 'environment_manipulation'),
           (r'setfenv\s*\(\s*1', 'environment_manipulation'),
           (r'debug\.getinfo', 'debug_api_usage'),
           (r'debug\.getupvalue', 'debug_api_usage'),
           (r'debug\.setupvalue', 'debug_api_usage'),
           (r'while\s+true\s+do\s*end', 'infinite_loop'),
           (r'for\s+\w+\s+in\s+pairs\s*\(\s*\{\s*\}\s*\)\s+do\s+end', 'empty_loop'),
           (r'pcall\s*\(\s*error', 'error_obfuscation'),
           (r'string\.dump\s*\(\s*\w+\s*\)', 'bytecode_extraction'),
           (r'collectgarbage\s*\(\s*["\']count["\']', 'memory_tracking'),
       ]
       
       for pattern, desc in suspicious:
           if re.search(pattern, code):
               results['suspicious_constructs'].append(desc)
       
       results['complexity_score'] = self._calculate_complexity(code)
       
       return results
   
   def _calculate_entropy(self, data: str) -> float:
       if not data:
           return 0.0
       
       entropy = 0.0
       for x in range(256):
           p_x = float(data.count(chr(x))) / len(data)
           if p_x > 0:
               entropy += - p_x * math.log(p_x, 2)
       
       return entropy
   
   def _calculate_complexity(self, code: str) -> int:
       score = 0
       score += len(re.findall(r'if|then|else|elseif', code)) * 2
       score += len(re.findall(r'while|for|repeat|until', code)) * 3
       score += len(re.findall(r'function|local function', code)) * 5
       score += len(re.findall(r'pcall|xpcall|loadstring', code)) * 10
       score += len(re.findall(r'getfenv|setfenv|debug\.', code)) * 15
       return score

class ShadowDeobfuscator:
   def __init__(self):
       self.ast_transformer = ASTTransformer()
       self.control_flow = ControlFlowAnalyzer()
       self.vmr = VMR()
       self.beautifier = CodeBeautification()
       self.anti_tamper = ShadowAntiTamper()
       self.crypto = ShadowCryptography()
       self.heuristic = ShadowHeuristicEngine()
       self.ai = ShadowAIEngine()
   
   def deobfuscate(self, code: str, aggressive: bool = False, deep_analysis: bool = False) -> Dict[str, Any]:
       original = code
       steps = []
       
       code = self.anti_tamper.neutralize(code)
       steps.append('neutralized_anti_tamper')
       
       code = self.ast_transformer.transform(code)
       steps.append('ast_transformation')
       
       code = self.control_flow.analyze(code)
       steps.append('control_flow_analysis')
       
       crypto_results = self.crypto.try_decrypt(code.encode())
       if crypto_results:
           code = crypto_results[0][1].decode('utf-8', errors='ignore')
           steps.append(f'decrypted_{crypto_results[0][0]}')
       
       code = self.vmr.reconstruct(code, deep_analysis)
       steps.append('vm_reconstruction')
       
       heuristic_analysis = self.heuristic.analyze(code)
       steps.append('heuristic_analysis')
       
       code = self.beautifier.beautify(code, aggressive)
       steps.append('beautification')
       
       if aggressive:
           code = self.ai.multi_pass(code, passes=3, mode='deobfuscate')
           steps.append('ai_optimization')
       
       final_analysis = self.heuristic.analyze(code)
       
       return {
           'original': original,
           'deobfuscated': code,
           'steps': steps,
           'heuristic_before': heuristic_analysis,
           'heuristic_after': final_analysis,
           'entropy_reduction': heuristic_analysis['entropy'] - final_analysis['entropy'],
           'complexity_reduction': heuristic_analysis['complexity_score'] - final_analysis['complexity_score'],
       }

class ShadowBatchProcessor:
   def __init__(self):
       self.deobfuscator = ShadowDeobfuscator()
       self.results = []
   
   def process_file(self, filepath: str, aggressive: bool = False) -> Dict[str, Any]:
       with open(filepath, 'r', encoding='utf-8', errors='ignore') as f:
           code = f.read()
       
       result = self.deobfuscator.deobfuscate(code, aggressive)
       result['filepath'] = filepath
       self.results.append(result)
       return result
   
   def process_directory(self, directory: str, pattern: str = '*.lua', aggressive: bool = False) -> List[Dict[str, Any]]:
       import glob
       files = glob.glob(os.path.join(directory, pattern))
       
       for filepath in files:
           try:
               self.process_file(filepath, aggressive)
           except Exception as e:
               self.results.append({
                   'filepath': filepath,
                   'error': str(e),
               })
       
       return self.results
   
   def export_results(self, output_dir: str, format: str = 'json'):
       os.makedirs(output_dir, exist_ok=True)
       
       for i, result in enumerate(self.results):
           if 'error' in result:
               continue
           
           base_name = os.path.basename(result['filepath'])
           name, _ = os.path.splitext(base_name)
           
           output_path = os.path.join(output_dir, f'{name}_clean.lua')
           with open(output_path, 'w', encoding='utf-8') as f:
               f.write(result['deobfuscated'])
           
           if format == 'json':
               report_path = os.path.join(output_dir, f'{name}_report.json')
               with open(report_path, 'w', encoding='utf-8') as f:
                   json.dump({
                       'steps': result['steps'],
                       'heuristic_before': result['heuristic_before'],
                       'heuristic_after': result['heuristic_after'],
                       'entropy_reduction': result['entropy_reduction'],
                       'complexity_reduction': result['complexity_reduction'],
                   }, f, indent=2)

