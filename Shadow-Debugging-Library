           r'if\s+\w+\s*~=\s*\w+\s*then\s*return\s+end',
           r'assert\s*\(\s*false[^)]*\)',
           r'error\s*\(\s*["\'][^"\']*["\']\s*\)',
           r'while\s+true\s+do\s*end',
           r'for\s+\w+\s+in\s+pairs\s*\(\s*\{\s*\}\s*\)\s+do\s+end',
